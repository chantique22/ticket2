datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// User & Auth Models
enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // For credentials provider
  role          Role      @default(USER)
  division      String?
  pc_name       String? // Default PC name

  accounts Account[]
  sessions Session[]

  tickets         Ticket[]
  assignedTickets Ticket[] @relation("AssignedTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Ticketing System Models

enum TicketStatus {
  OPEN
  ON_HOLD
  ON_GOING
  RESOLVED
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  subCategories SubCategory[]
  tickets       Ticket[]
}

model SubCategory {
  id         Int      @id @default(autoincrement())
  name       String
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  tickets    Ticket[]

  @@unique([name, categoryId])
}

model Ticket {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Part A: User Info Snapshot
  userId String
  user   User    @relation(fields: [userId], references: [id])
  pcName String? // Snapshot of PC name at time of ticket

  // Part B: Problem Details
  categoryId    Int
  category      Category    @relation(fields: [categoryId], references: [id])
  subCategoryId Int
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])
  details       String      @db.Text

  // Status & Priority
  status   TicketStatus @default(OPEN)
  priority String       @default("Normal") // Normal, High, Critical

  // Assignment
  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  // Admin Analysis (Ticket Analysis)
  analysis      String? @db.Text
  correction    String? @db.Text // Perbaikan
  prevention    String? @db.Text // Preventif
  action        String? @db.Text
  problemStatus String? @db.Text // Status Problem specific text
}
